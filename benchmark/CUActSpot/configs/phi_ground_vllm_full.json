{
  "dataset": {
    "data_dir": "data/ActSpot"
  },
  "model": {
    "name": "phi-ground-vllm-full",
    "preset": "phi_ground_vllm",
    "backend": {
      "target": "phi_ground_vllm",
      "kwargs": {
        "model": "microsoft/Phi-Ground",
        "tensor_parallel_size": 1,
        "trust_remote_code": true,
        "max_num_seqs": 8,
        "max_model_len": 4096
      }
    },
    "generation": {
      "temperature": 0.0,
      "max_tokens": 64
    }
  },
  "output": {
    "output_dir": "outputs/phi_ground_vllm_full",
    "report_file": "report.json",
    "overwrite": true
  }
}